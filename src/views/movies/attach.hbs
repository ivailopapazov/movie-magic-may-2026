{{setTitle 'Attach Cast'}}

<section id="attachCast">
    <div class="attachCastSection">
        <h1>Attach New Cast</h1>
        <div class="attach-form">
            <h2>{{movie.title}}</h2>
            <img class="movie" src="{{movie.imageUrl}}" alt="{{movie.title}}">
            <form method="POST">
                <label for="cast">Cast</label>
                <select id="cast" name="artist">
                    <option value="none" selected>--------</option>
                    {{#each artists}}
                    <option value="{{id}}">{{name}}</option>
                    {{/each}}
                </select>
                <div style="width: 50%; display:flex; justify-content: center;">
                    <label for="name-in-movie">Name:</label>
                    <input type="text" class="inputFields" id="name-in-movie" name="character" />
                </div>
                <div id="center-btn">
                    <button id="create-btn">Add Cast</button>
                </div>
            </form>
        </div>
    </div>
</section>
